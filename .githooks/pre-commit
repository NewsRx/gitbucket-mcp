#!/usr/bin/env python3
"""
Pre-commit hook: BLOCK commits to main branch from AI agents.

Detects AI agent via OPENCODE_ environment variables and blocks commits to main.

Exit codes:
  0: Allow commit (not on main OR human user)
  1: Block commit (on main AND AI detected)
"""

import os
import subprocess
import sys


PROTECTED_BRANCHES = ("main", "master")


def get_current_branch() -> str:
    """Get the current branch name."""
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def is_ai_agent() -> bool:
    """Check if OpenCode AI agent is running."""
    for key in os.environ:
        if key.startswith("OPENCODE_"):
            return True
    return False


def main() -> int:
    """Block commits to main from AI agents."""
    branch = get_current_branch()

    if branch in PROTECTED_BRANCHES and is_ai_agent():
        print("\n" + "=" * 70, file=sys.stderr)
        print("🚫 BLOCKED: AI agent cannot commit to 'main' branch", file=sys.stderr)
        print("=" * 70, file=sys.stderr)
        print("\nThe feature-branch workflow is MANDATORY.", file=sys.stderr)
        print("\nTo make changes:", file=sys.stderr)
        print("  1. Create a feature branch:", file=sys.stderr)
        print("       git checkout -b feature/<description>", file=sys.stderr)
        print("  2. Make your changes and commit", file=sys.stderr)
        print("  3. Push and create a PR\n", file=sys.stderr)
        print("=" * 70 + "\n", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())